FROM nvidia/cuda:11.8.0-cudnn8-runtime-ubuntu22.04 AS phase1-base

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    python3.10 python3.10-venv python3-pip \
    libgl1-mesa-glx libglib2.0-0 curl \
    && rm -rf /var/lib/apt/lists/*

# ─── Phase 2 Final Image ──────────────────────────────────────────────────────
FROM phase1-base AS phase2

WORKDIR /app

# Phase 2 deps (includes transformers, peft, bitsandbytes, trl)
COPY requirements_phase2.txt .
RUN pip3 install --no-cache-dir -r requirements_phase2.txt

# App code
COPY src/ src/
COPY configs/ configs/
RUN mkdir -p models/vision models/llm data/processed notebooks/sample_augmentations

ENV PHASE=2
ENV DEVICE=cuda
ENV LOG_LEVEL=info

EXPOSE 8000 7860

COPY docker/start_phase2.sh /start.sh
RUN chmod +x /start.sh

CMD ["/start.sh"]
