logs/
*.log
*.out
*.err

# Large output files and demo images (not needed for deployment)
outputs/
notebooks/sample_augmentations/
trace.txt
output_test1.txt
output_utf8.txt
debug_output_final.txt

# WandB
wandb/

# Frontend
frontend/node_modules/
# frontend/dist is intentionally NOT ignored — needed for HuggingFace Spaces deployment

